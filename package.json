{
  "name": "mohit-industries",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "clean": "rimraf .next",
    "build": "next build",
    "postbuild": "rimraf build-cache.json",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "ts-node --project prisma/tsconfig.seed.json prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:reset": "prisma migrate reset --force",
    "db:rebuild-categories": "node scripts/rebuild-category-tree.js",
    "db:rebuild-categories:dry": "DRY_RUN=1 node scripts/rebuild-category-tree.js",
    "test": "vitest run"
  },
  "prisma": {
    "seed": "ts-node --project prisma/tsconfig.seed.json prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "jose": "^5.2.4",
    "lru-cache": "^11.5.1",
    "lucide-react": "^0.368.0",
    "next": "^14.2.3",
    "nodemailer": "^6.9.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.12.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.5.0",
    "clean-css": "^5.3.3",
    "lighthouse": "^13.4.0",
    "postcss": "^8.5.15",
    "prisma": "^5.22.0",
    "rimraf": "^6.1.3",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.8"
  }
}
