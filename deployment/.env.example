# ═══════════════════════════════════════════════════════
# docker-compose variables (deployment/docker-compose.yml)
# ═══════════════════════════════════════════════════════
# 1. Copy this file:  cp deployment/.env.example deployment/.env
# 2. Fill in real values.  NEVER commit deployment/.env (it is gitignored).
# 3. App-level secrets (JWT_SECRET, SMTP, Cloudinary, GA, …) live in the
#    repo-root .env — see ../.env.example.
# ═══════════════════════════════════════════════════════

# Postgres (the `db` service). Use a STRONG password.
# Tip: keep it alphanumeric so it needs no URL-encoding in the DB connection
# string. If it contains @ : / etc., URL-encode them in DATABASE_URL inside
# docker-compose.yml (e.g. @ -> %40).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=mohit_industries

# Public production URL (overrides the app default).
NEXT_PUBLIC_SITE_URL=https://mohitscpl.com
