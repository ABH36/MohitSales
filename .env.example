# ═══════════════════════════════════════════════════════
# Mohit Industries — Environment Variables Template
# ═══════════════════════════════════════════════════════
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values below
# 3. NEVER commit your .env file to Git
# ═══════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/mohit_industries?schema=public"
# Direct connection string to database (Prisma requires this when using serverless/connection-poolers. Can be same as DATABASE_URL for local setup)
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/mohit_industries?schema=public"

# ─── Authentication ────────────────────────────────────
# Strong random secret for JWT signing (min 32 characters)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret-in-production"

# ─── SMTP — Email Configuration ────────────────────────
# Gmail SMTP (recommended for Gmail accounts)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"

# Gmail account that sends emails
# Use an App Password (not your regular password):
# Google Account → Security → 2-Step Verification → App passwords
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"

# ─── Email Recipients ──────────────────────────────────
# Where enquiry form emails are sent
SMTP_TO_INQUIRY="info@yourdomain.com"

# Where feedback form emails are sent
SMTP_TO_FEEDBACK="info@yourdomain.com"

# BCC recipient for all emails (leave empty to disable)
SMTP_BCC=""

# ─── Site Configuration ────────────────────────────────
# Your production domain (used in email footers, SEO, etc.)
NEXT_PUBLIC_SITE_URL="https://mohitscpl.com"

# Default locale (keep as "en" unless multi-language is set up)
NEXT_PUBLIC_DEFAULT_LOCALE="en"

# ─── Cloudinary (Media CDN) ───────────────────────────
# Cloudinary Name, API Key, and Secret for image/pdf storage
CLOUDINARY_CLOUD_NAME="your_cloud_name_here"
CLOUDINARY_API_KEY="your_api_key_here"
CLOUDINARY_API_SECRET="your_api_secret_here"

