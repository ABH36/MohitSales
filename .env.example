# ═══════════════════════════════════════════════════════
# Mohit Industries — Environment Variables Template
# ═══════════════════════════════════════════════════════
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values below
# 3. NEVER commit your .env file to Git
# ═══════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@187.127.146.111:5432/mohit_industries?schema=public"
# Direct connection string to database (Prisma requires this when using serverless/connection-poolers. Can be same as DATABASE_URL for local setup)
DIRECT_URL="postgresql://USER:PASSWORD@187.127.146.111:5432/mohit_industries?schema=public"

# ─── Authentication ────────────────────────────────────
# Strong random secret for JWT signing (min 32 characters)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret-in-production"

# ─── SMTP — Email Configuration ────────────────────────
# Gmail SMTP (recommended for Gmail accounts)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"

# Gmail account that sends emails
# Use an App Password (not your regular password):
# Google Account → Security → 2-Step Verification → App passwords
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"

# ─── Email Recipients ──────────────────────────────────
# Where enquiry form emails are sent
SMTP_TO_INQUIRY="info@mohitscpl.com"

# Where feedback form emails are sent
SMTP_TO_FEEDBACK="info@mohitscpl.com"

# BCC recipient for all emails (leave empty to disable)
SMTP_BCC=""

# ─── Site Configuration ────────────────────────────────
# Your production domain (used in email footers, SEO, etc.)
NEXT_PUBLIC_SITE_URL="https://mohitscpl.com"

# Default locale (keep as "en" unless multi-language is set up)
NEXT_PUBLIC_DEFAULT_LOCALE="en"

# Disable rate limiting on APIs (set to true for load testing/staging verification)
DISABLE_RATE_LIMITER="false"

# Set to false if deploying a production build over raw HTTP (without HTTPS/SSL)
SECURE_COOKIE="true"

# ─── Cloudinary (Media CDN) ───────────────────────────
# Cloudinary Name, API Key, and Secret for image/pdf storage
CLOUDINARY_CLOUD_NAME="your_cloud_name_here"
CLOUDINARY_API_KEY="your_api_key_here"
CLOUDINARY_API_SECRET="your_api_secret_here"

# ─── Google Analytics ─────────────────────────────────
# Public GA4 measurement ID for on-site tracking (gtag.js). Leave EMPTY on
# staging/dev to disable tracking so those visits don't pollute the prod property.
# Defaults to the production ID (G-FZF80T7820) when unset.
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-FZF80T7820"

# Admin → Analytics → "Google Analytics" tab reads real GA4 metrics via the
# Data API. Without all three below it falls back to clearly-labelled demo data.
# Create a Google Cloud service account, enable the "Google Analytics Data API",
# and grant that service-account email Viewer access on the GA4 property.
# GA_PROPERTY_ID = the numeric GA4 property id (NOT the G-XXXX measurement id).
GA_PROPERTY_ID=""
GA_CLIENT_EMAIL="service-account@your-project.iam.gserviceaccount.com"
# Paste the private key with literal \n escapes (keep the quotes):
GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

